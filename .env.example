DEBUG=0
DJANGO_SETTINGS_MODULE=config.settings
POSTGRES_DB=<database_name>
POSTGRES_USER=<username>
POSTGRES_PASSWORD=<password>
DB_HOST=<hostname>
DB_PORT=<port>
DOCLING_URL= <docling_service_url>

# AI Comments LLM Configuration (OpenAI)
AI_COMMENTS_LLM_TYPE=<llm_type>
AI_COMMENTS_LLM_API_KEY=<api_key>
AI_COMMENTS_LLM_API_URL=<api_url>
AI_COMMENTS_LLM_API_VERSION=<api_version>
AI_COMMENTS_LLM_MODEL_NAME=<model_name>

# SQL Query Generation LLM Configuration (Claude)
SQL_QUERY_LLM_TYPE=<llm_type>
SQL_QUERY_LLM_MODEL_NAME=<model_name>

# Legacy settings (kept for backward compatibility)
LLM_TYPE=<llm_type>
LLM_API_KEY=<api_key>
LLM_API_URL=<api_url>
LLM_API_VERSION=<api_version>
LLM_NAME=<model_name>
LLM_VANNA_MODEL_NAME=<model_name>

# Qdrant Configuration
QDRANT_URL=<qdrant_url>
QDRANT_API_KEY=<qdrant_api_key>
QDRANT_COLLECTION_NAME=<collection_name>
QDRANT_QUERY_LIMIT=<query_limit>

# Other settings
MAX_LLM_RETRIES=<max_retries>
LLM_PROMPT_FILE=<prompt_file_path>
ANTHROPIC_API_KEY=<anthropic_api_key>



# Azure Communication Services SMTP Configuration
EMAIL_HOST=<smtp_host>
EMAIL_PORT=<smtp_port>
EMAIL_USE_TLS=<true_or_false>
EMAIL_HOST_USER=<smtp_username>
EMAIL_HOST_PASSWORD=<smtp_password>
DEFAULT_FROM_EMAIL=<default_from_email>